# Copy this file's variable names into your Supabase project's Edge Function
# secrets (Project Settings -> Edge Functions -> Secrets, or via the CLI:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-your-real-key-here
# ). Never commit real values — this file only documents the variable names.

# Required. Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=claude-sonnet-4-6
